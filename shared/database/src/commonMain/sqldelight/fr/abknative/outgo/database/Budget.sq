/**
 * Inserts a new budget. Fails if the ID already exists.
 */
insertBudget:
INSERT INTO BudgetEntity(id, monthlyIncomeInCents)
VALUES (?, ?);

/**
 * Updates an existing budget's income by its ID.
 */
updateBudget:
UPDATE BudgetEntity
SET monthlyIncomeInCents = ?
WHERE id = ?;

getBudgetById:
SELECT * FROM BudgetEntity WHERE id = ?;


getActiveOutgoings:
SELECT * FROM OutgoingEntity
WHERE isDeleted = 0;